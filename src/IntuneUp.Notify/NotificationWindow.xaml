<Window x:Class="IntuneUp.Notify.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IntuneUp Notification"
        Width="500" MinHeight="250" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True">

    <Border Background="White" CornerRadius="8" 
            BorderBrush="#E0E0E0" BorderThickness="1"
            Margin="10"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header band -->
                <RowDefinition Height="*"/>     <!-- Content -->
                <RowDefinition Height="Auto"/>  <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header band with accent color -->
            <Border Grid.Row="0" Background="#0078D4" CornerRadius="8,8,0,0" Padding="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="LogoImage" Width="28" Height="28" Margin="0,0,12,0"
                           Visibility="Collapsed"/>
                    <TextBlock x:Name="IconText" FontSize="22" Foreground="White" 
                               Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="OrgText" FontSize="11" Foreground="#B0D4F1"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="White" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Content area -->
            <StackPanel Grid.Row="1" Margin="24,20,24,16">
                <TextBlock x:Name="SubtitleText" FontSize="14" FontWeight="Medium"
                           Foreground="#333333" Margin="0,0,0,8" TextWrapping="Wrap"
                           Visibility="Collapsed"/>
                <TextBlock x:Name="BodyText" FontSize="13" Foreground="#555555"
                           TextWrapping="Wrap" LineHeight="20"/>
                <TextBlock x:Name="TimeoutText" FontSize="11" Foreground="#999999"
                           Margin="0,12,0,0" Visibility="Collapsed"/>
            </StackPanel>

            <!-- Button bar -->
            <Border Grid.Row="2" BorderBrush="#F0F0F0" BorderThickness="0,1,0,0"
                    Padding="24,12">
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" 
                            HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </Border>

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow" BlurRadius="20" ShadowDepth="4"
                          Opacity="0.3" Color="#000000"/>
    </Window.Resources>
</Window>
