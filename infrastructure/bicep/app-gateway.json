{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "17196489463510332876"
    }
  },
  "parameters": {
    "name": {
      "type": "string",
      "defaultValue": "agw-intuneup-dev"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "tags": {
      "type": "object",
      "defaultValue": {}
    },
    "functionAppHostname": {
      "type": "string",
      "metadata": {
        "description": "Hostname of the backend Function App (e.g. func-intuneup-http-dev.azurewebsites.net)"
      }
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "vnet-intuneup-dev",
      "metadata": {
        "description": "VNet name to place the App Gateway in"
      }
    },
    "gatewaySubnetPrefix": {
      "type": "string",
      "defaultValue": "192.168.0.64/27",
      "metadata": {
        "description": "Address prefix for the App Gateway subnet (must be in the VNet range, minimum /27)"
      }
    },
    "wafMode": {
      "type": "string",
      "defaultValue": "Prevention",
      "allowedValues": [
        "Detection",
        "Prevention"
      ],
      "metadata": {
        "description": "WAF mode: Detection (log only) or Prevention (block)"
      }
    },
    "capacity": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "maxValue": 10,
      "metadata": {
        "description": "SKU capacity (instance count)"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Network/virtualNetworks/subnets",
      "apiVersion": "2023-11-01",
      "name": "[format('{0}/{1}', parameters('vnetName'), 'snet-appgateway')]",
      "properties": {
        "addressPrefix": "[parameters('gatewaySubnetPrefix')]"
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-11-01",
      "name": "[format('pip-{0}', parameters('name'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static",
        "dnsSettings": {
          "domainNameLabel": "[parameters('name')]"
        }
      }
    },
    {
      "type": "Microsoft.Network/ApplicationGatewayWebApplicationFirewallPolicies",
      "apiVersion": "2023-11-01",
      "name": "[format('waf-{0}', parameters('name'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "policySettings": {
          "state": "Enabled",
          "mode": "[parameters('wafMode')]",
          "requestBodyCheck": true,
          "maxRequestBodySizeInKb": 512,
          "fileUploadLimitInMb": 1
        },
        "managedRules": {
          "managedRuleSets": [
            {
              "ruleSetType": "OWASP",
              "ruleSetVersion": "3.2"
            },
            {
              "ruleSetType": "Microsoft_BotManagerRuleSet",
              "ruleSetVersion": "1.0"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Network/applicationGateways",
      "apiVersion": "2023-11-01",
      "name": "[parameters('name')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "WAF_v2",
          "tier": "WAF_v2",
          "capacity": "[parameters('capacity')]"
        },
        "firewallPolicy": {
          "id": "[resourceId('Microsoft.Network/ApplicationGatewayWebApplicationFirewallPolicies', format('waf-{0}', parameters('name')))]"
        },
        "gatewayIPConfigurations": [
          {
            "name": "gatewayIpConfig",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), 'snet-appgateway')]"
              }
            }
          }
        ],
        "frontendIPConfigurations": [
          {
            "name": "frontendIp",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', format('pip-{0}', parameters('name')))]"
              }
            }
          }
        ],
        "frontendPorts": [
          {
            "name": "port443",
            "properties": {
              "port": 443
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "functionBackend",
            "properties": {
              "backendAddresses": [
                {
                  "fqdn": "[parameters('functionAppHostname')]"
                }
              ]
            }
          }
        ],
        "backendHttpSettingsCollection": [
          {
            "name": "httpsSettings",
            "properties": {
              "port": 443,
              "protocol": "Https",
              "cookieBasedAffinity": "Disabled",
              "requestTimeout": 30,
              "pickHostNameFromBackendAddress": true,
              "probe": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/probes', parameters('name'), 'healthProbe')]"
              }
            }
          }
        ],
        "httpListeners": [
          {
            "name": "httpsListener",
            "properties": {
              "frontendIPConfiguration": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/frontendIPConfigurations', parameters('name'), 'frontendIp')]"
              },
              "frontendPort": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/frontendPorts', parameters('name'), 'port443')]"
              },
              "protocol": "Https"
            }
          }
        ],
        "requestRoutingRules": [
          {
            "name": "routeToFunction",
            "properties": {
              "ruleType": "Basic",
              "priority": 100,
              "httpListener": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/httpListeners', parameters('name'), 'httpsListener')]"
              },
              "backendAddressPool": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/backendAddressPools', parameters('name'), 'functionBackend')]"
              },
              "backendHttpSettings": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/backendHttpSettingsCollection', parameters('name'), 'httpsSettings')]"
              }
            }
          }
        ],
        "probes": [
          {
            "name": "healthProbe",
            "properties": {
              "protocol": "Https",
              "host": "[parameters('functionAppHostname')]",
              "path": "/api/collect",
              "interval": 30,
              "timeout": 10,
              "unhealthyThreshold": 3,
              "pickHostNameFromBackendHttpSettings": false,
              "match": {
                "statusCodes": [
                  "200-499"
                ]
              }
            }
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), 'snet-appgateway')]",
        "[resourceId('Microsoft.Network/publicIPAddresses', format('pip-{0}', parameters('name')))]",
        "[resourceId('Microsoft.Network/ApplicationGatewayWebApplicationFirewallPolicies', format('waf-{0}', parameters('name')))]"
      ]
    }
  ],
  "outputs": {
    "appGatewayId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/applicationGateways', parameters('name'))]"
    },
    "publicIpAddress": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', format('pip-{0}', parameters('name'))), '2023-11-01').ipAddress]"
    },
    "publicFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses', format('pip-{0}', parameters('name'))), '2023-11-01').dnsSettings.fqdn]"
    }
  }
}